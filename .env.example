# Copy this file to .env and fill in the values for the provider you use.
# Never commit .env to source control.

# ---- Default provider / model (optional) ----
HSCODE_PROVIDER=openai
HSCODE_MODEL=gpt-5.4-nano

# ---- Cache & behaviour ----
# HSCODE_CACHE_DIR=~/.cache/hscode
# HSCODE_CN_YEAR=2026
# HSCODE_MAX_RETRIES=3
# HSCODE_LOG_LEVEL=INFO

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- Azure OpenAI ----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- Anthropic ----
ANTHROPIC_API_KEY=

# ---- Google Gemini ----
GOOGLE_API_KEY=

# ---- Ollama (local) ----
OLLAMA_HOST=http://localhost:11434

# ---- OpenRouter (https://openrouter.ai) ----
# Use a fully-qualified model slug for HSCODE_MODEL, e.g.:
#   openai/gpt-5.4-nano, anthropic/claude-haiku-4.5, google/gemini-3.1-flash-lite
OPENROUTER_API_KEY=
